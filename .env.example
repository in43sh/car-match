# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite database file (relative to project root)
DATABASE_URL=./data/car-match.db

# ── Authentication ─────────────────────────────────────────────────────────────
# Secret for dashboard session cookie — generate with: openssl rand -base64 32
AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32

# Single-user dashboard password
DASHBOARD_PASSWORD=change-me

# ── Telegram ───────────────────────────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Your personal Telegram user ID (get from @userinfobot)
TELEGRAM_ALLOWED_USER_ID=123456789

# ── Scraper ────────────────────────────────────────────────────────────────────
# How often to run the scraper (minutes)
SCRAPE_INTERVAL_MINUTES=5

# Path to saved Facebook session cookies
FB_SESSION_PATH=./data/fb-session.json

# ── Next.js ────────────────────────────────────────────────────────────────────
# Only needed if deploying with a custom domain
# NEXTAUTH_URL=http://localhost:3000
